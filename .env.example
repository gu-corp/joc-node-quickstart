# Network to sync: mainnet (chain 81) | testnet (chain 10081)
NETWORK=mainnet

# Override official bootnodes if needed (comma-separated enode URLs).
# Leave empty to use the defaults baked into scripts/entrypoint.sh.
BOOTNODES=

# Host ports
HTTP_RPC_PORT=8545
WS_RPC_PORT=8546
P2P_PORT=30303

# Enabled RPC API namespaces
HTTP_APIS=eth,net,web3,txpool
WS_APIS=eth,net,web3
