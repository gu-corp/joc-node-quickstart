# Override official bootnodes if needed (comma-separated enode URLs).
# Leave empty to use the defaults baked into ./entrypoint.sh.
BOOTNODES=

# Host ports (offset from mainnet defaults so both nodes can run side by side)
HTTP_RPC_PORT=18545
WS_RPC_PORT=18546
P2P_PORT=30304

# Enabled RPC API namespaces
HTTP_APIS=eth,net,web3,txpool
WS_APIS=eth,net,web3
