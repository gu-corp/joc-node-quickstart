# Geth image tag (v1.13.5 is the version officially tested by JOC)
GETH_VERSION=v1.13.5

# Override official bootnodes if needed (comma-separated enode URLs).
# Leave empty to use the defaults baked into ./entrypoint.sh.
BOOTNODES=

# Host ports
HTTP_RPC_PORT=8545
WS_RPC_PORT=8546
P2P_PORT=30303

# Enabled RPC API namespaces
HTTP_APIS=eth,net,web3,txpool
WS_APIS=eth,net,web3

# Sync/state modes (geth --syncmode / --gcmode)
# SYNCMODE: full (execute every block; JOC official) | snap
# GCMODE: full (pruned state) | archive (keep all historical state, needs TBs of disk)
SYNCMODE=full
GCMODE=full

# Optional explorer (docker compose --profile explorer up -d)
EXPLORER_PORT=8080
# RPC URL as seen from the user's browser
EXPLORER_NODE_URL=http://localhost:8545
